// SAWA Command Center — data model (see SPEC.md §6)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Postgres for deploy. Uses Neon's direct (non-pooling) URL that the Vercel
  // integration provides. For purely-local SQLite dev, temporarily set
  // provider = "sqlite" / url = "file:./dev.db". (See SPEC.md §8.)
  provider = "postgresql"
  url      = env("POSTGRES_URL_NON_POOLING")
}

// One record per person.
model Lead {
  id            Int      @id @default(autoincrement())
  name          String
  title         String
  company       String
  linkedinUrl   String?  @unique
  email         String?
  channel       String   // "outbound" | "inbound" | "both"
  stage         String   // see stage lists in SPEC.md §2
  emailSuppressed Boolean @default(false)
  notes         String?

  meetingAt     DateTime?
  meetingEmail  String?

  events        Event[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// The timeline — one row per thing that happened.
model Event {
  id        Int      @id @default(autoincrement())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    Int
  type      String   // connection_sent | connected | message_sent | replied | signed_up | emailed | booked | cancelled
  at        DateTime @default(now())
}

// Items the Reconciliation Queue couldn't place with certainty.
model ReviewItem {
  id        Int      @id @default(autoincrement())
  reason    String
  payload   String
  createdAt DateTime @default(now())
}

// LinkedIn content posts (Artefacts → Posts calendar, SPEC.md §4).
model Post {
  id            Int      @id @default(autoincrement())
  hook          String   // short calendar label
  body          String   // the LinkedIn post text
  scheduledDate DateTime // intended publish day
  status        String   // "draft" | "scheduled" | "live"
  note          String?  // internal SAWA note
  approved      Boolean  @default(false) // Adam's optional approve
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Outbound outreach copy (Artefacts → Outreach messages). The LinkedIn/email
// messages that go out to leads; Adam reviews, edits, and approves them — the
// same edit/save/approve mechanism as Post.
model OutreachMessage {
  id        Int      @id @default(autoincrement())
  channel   String   // "linkedin" | "email"
  label     String   // e.g. "Connection request note", "Follow-up #1"
  step      Int      // ordering within its channel's sequence
  meta      String?  // when it sends, e.g. "day 2 after connect"
  subject   String?  // email subject line (email channel only)
  body      String   // the message copy
  status    String   // "needs_review" | "scheduled" | "live"
  note      String?  // internal SAWA note
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
